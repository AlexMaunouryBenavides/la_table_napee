{
  // Hérite du contrat de rigueur commun (strict + flags pro), puis ajoute
  // uniquement les options d'ENVIRONNEMENT propres à un service NestJS (Node).
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,

    // Requis par NestJS : les décorateurs (@Module, @Injectable, @Get…) et la
    // métadonnée de type émise pour l'injection de dépendances.
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true
  }
}
