# Copie ce fichier en `.env` (non commité) et adapte les valeurs.

# REQUIS — origine exacte du front pour le CORS crédentialisé. Jamais "*".
FRONT_ORIGIN=http://localhost:5173

# Optionnel — port d'écoute de l'API (défaut 3000).
PORT=3000

# Optionnel — development | production | test (défaut development).
NODE_ENV=development

# Optionnel — anti-bruteforce : fenêtre en millisecondes et nombre de requêtes.
THROTTLER_TTL=60000
THROTTLER_LIMIT=100

# Optionnel — niveau de log pino : trace|debug|info|warn|error|fatal (défaut info).
LOG_LEVEL=info
