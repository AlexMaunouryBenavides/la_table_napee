# EditorConfig — réglages bas niveau appliqués pendant la frappe, dans tout éditeur.
# Agit AVANT Prettier : garantit fins de ligne / charset / indentation cohérents
# dès la saisie, ce qui évite les diffs git pollués (surtout CRLF vs LF sur Windows).
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# En Markdown, deux espaces en fin de ligne = saut de ligne volontaire :
# on ne les supprime donc pas automatiquement.
[*.md]
trim_trailing_whitespace = false
